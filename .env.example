# Copy to .env and fill in. Never commit the real .env file.

# Optional: if set, all /api/* requests to the web UI must send a matching
# X-API-Key header. Leave unset for open local development.
NGS_API_KEY=

# Optional: set to "true" to enable Flask debug mode for local web UI development.
# Never enable this in any environment reachable by untrusted users.
FLASK_DEBUG=false
